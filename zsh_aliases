# Full system cleanup
updatefull() {
    echo "🔄 Updating system..."
    sudo apt update
    sudo apt upgrade -y
    sudo apt autoremove -y
    sudo apt autoclean
    echo "✅ System fully updated and cleaned."
}

# Quick conda environment creation
mkconda() {
    if [ -z "$1" ]; then
        echo "Usage: mkconda <env_name> [python_version]"
        return 1
    fi

    PYVER=${2:-3.11}
    conda create -n "$1" python="$PYVER" -y
    echo "✅ Conda environment '$1' created with Python $PYVER"
}

# Quick extract helper
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2) tar xjf "$1" ;;
            *.tar.gz)  tar xzf "$1" ;;
            *.bz2)     bunzip2 "$1" ;;
            *.rar)     unrar x "$1" ;;
            *.gz)      gunzip "$1" ;;
            *.tar)     tar xf "$1" ;;
            *.tbz2)    tar xjf "$1" ;;
            *.tgz)     tar xzf "$1" ;;
            *.zip)     unzip "$1" ;;
            *.Z)       uncompress "$1" ;;
            *.7z)      7z x "$1" ;;
            *) echo "❌ Cannot extract '$1'" ;;
        esac
    else
        echo "❌ '$1' is not a valid file"
    fi
}

